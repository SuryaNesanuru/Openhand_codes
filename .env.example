# Agent Platform Environment Variables
# Copy to .env and customize

# ===================
# Database
# ===================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_platform

# ===================
# Redis
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# Auth
# ===================
SECRET_KEY=changeme-generate-random-string-in-production
JWT_EXPIRE_DAYS=7

# ===================
# LLM Providers
# ===================

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=sk-

# OpenRouter
OPENROUTER_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ===================
# External Services
# ===================
# TAVILY_API_KEY=
# SERPER_API_KEY=

# ===================
# Optional: Langfuse (observability)
# ===================
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=

# ===================
# File Storage
# ===================
UPLOAD_DIR=./uploads